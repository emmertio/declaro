{
    "name": "declaro",
    "version": "1.0.0",
    "description": "Declarative Business Application Framework",
    "main": "index.js",
    "repository": "git@github.com:emmertio/declaro.git",
    "author": "Robby Emmert <robby@emmert.io>",
    "license": "MIT",
    "scripts": {
        "dev": "bun lerna run dev --parallel",
        "typecheck": "bun lerna run typecheck --parallel",
        "test": "bun lerna run test",
        "build": "bun lerna run --scope \"@declaro/*\" build",
        "release": "bun typecheck && bun test && bun build && bun lerna publish --force-publish",
        "prepare": "husky"
    },
    "workspaces": {
        "packages": [
            "lib/*",
            "apps/*"
        ]
    },
    "devDependencies": {
        "@tsconfig/node20": "^20.1.4",
        "husky": "^9.1.5",
        "lerna": "^7.0.2",
        "rimraf": "^6.0.1"
    },
    "packageManager": "bun@1.2.9"
}
